#!/bin/bash
#=====================================
#   AUTO RENEW EXECUTOR - FIXED VERSION
#   Dengan output channel yang lebih rapi
#=====================================

# ==========================================
# KONFIGURASI
# ==========================================
CONFIG_FILE="/etc/conf/config.json"
DB_PATH="/etc/conf/bot.db"
LOG_FILE="/var/log/auto-renew-executor.log"

# Warna output
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m'

# ==========================================
# FUNGSI LOGGING
# ==========================================
log() {
    echo -e "$(date '+%Y-%m-%d %H:%M:%S') - $1" | tee -a $LOG_FILE
}

# ==========================================
# FUNGSI SENSOR USERNAME
# ==========================================
sensor_username() {
    local username="$1"
    local visible_chars=4
    
    if [ ${#username} -le $visible_chars ]; then
        echo "$username"
    else
        local prefix="${username:0:$visible_chars}"
        local stars=$(printf '%*s' $((${#username} - $visible_chars)) '' | tr ' ' '*')
        echo "${prefix}${stars}"
    fi
}

# ==========================================
# FUNGSI GET USER INFO DARI DATABASE
# ==========================================
get_user_info() {
    local user_id=$1
    
    # Coba ambil dari database transaksi terakhir
    # Format: username|first_name
    local user_info=$(sqlite3 $DB_PATH "SELECT description FROM transaksi WHERE user_id = $user_id AND description LIKE '%Topup%' OR description LIKE '%Beli%' ORDER BY timestamp DESC LIMIT 1" 2>/dev/null | head -1)
    
    if [ -n "$user_info" ]; then
        # Extract username jika ada di description
        if [[ "$user_info" =~ @([a-zA-Z0-9_]+) ]]; then
            echo "${BASH_REMATCH[1]}"
        else
            echo "User$user_id"
        fi
    else
        echo "User$user_id"
    fi
}

# ==========================================
# FUNGSI BACA CONFIG.JSON (IMPROVED)
# ==========================================
read_config() {
    if [ ! -f "$CONFIG_FILE" ]; then
        log "${RED}❌ File config.json tidak ditemukan: $CONFIG_FILE${NC}"
        exit 1
    fi
    
    log "${GREEN}✅ Membaca config.json${NC}"
    
    # Baca token
    BOT_TOKEN=$(grep -o '"token": *"[^"]*"' "$CONFIG_FILE" | cut -d'"' -f4)
    
    # Baca channel ID
    CHANNEL_ID=$(grep -o '"id": *[-0-9]*' "$CONFIG_FILE" | grep -o '[-0-9]*' | head -1)
    
    # Baca harga
    PRICE_SSH=$(grep -o '"ssh": *[0-9]*' "$CONFIG_FILE" | grep -o '[0-9]*')
    PRICE_VMESS=$(grep -o '"vmess": *[0-9]*' "$CONFIG_FILE" | grep -o '[0-9]*')
    PRICE_VLESS=$(grep -o '"vless": *[0-9]*' "$CONFIG_FILE" | grep -o '[0-9]*')
    PRICE_TROJAN=$(grep -o '"trojan": *[0-9]*' "$CONFIG_FILE" | grep -o '[0-9]*')
    
    # Default harga jika tidak terbaca
    PRICE_SSH=${PRICE_SSH:-500}
    PRICE_VMESS=${PRICE_VMESS:-700}
    PRICE_VLESS=${PRICE_VLESS:-700}
    PRICE_TROJAN=${PRICE_TROJAN:-800}
    
    # Baca renew scripts dari config.json Anda
    RENEW_SSH="/etc/conf/api-renewssh.sh"
    RENEW_VMESS="/etc/conf/api-renewvm.sh"
    RENEW_VLESS="/etc/conf/api-renewvl.sh"
    RENEW_TROJAN="/etc/conf/api-renewtrj.sh"
    
    log "📌 Token: ${BOT_TOKEN:0:10}...${BOT_TOKEN: -5}"
    log "💰 Harga SSH: $PRICE_SSH, VMess: $PRICE_VMESS, VLess: $PRICE_VLESS, Trojan: $PRICE_TROJAN"
    
    # Verifikasi file script ada atau tidak
    check_script_exists
}

# ==========================================
# FUNGSI CEK KEBERADAAN SCRIPT
# ==========================================
check_script_exists() {
    log "${YELLOW}🔍 Memverifikasi keberadaan script renew:${NC}"
    
    [ -f "$RENEW_SSH" ] && log "✅ SSH: $RENEW_SSH ditemukan" || log "❌ SSH: $RENEW_SSH TIDAK ditemukan"
    [ -f "$RENEW_VMESS" ] && log "✅ VMess: $RENEW_VMESS ditemukan" || log "❌ VMess: $RENEW_VMESS TIDAK ditemukan"
    [ -f "$RENEW_VLESS" ] && log "✅ VLess: $RENEW_VLESS ditemukan" || log "❌ VLess: $RENEW_VLESS TIDAK ditemukan"
    [ -f "$RENEW_TROJAN" ] && log "✅ Trojan: $RENEW_TROJAN ditemukan" || log "❌ Trojan: $RENEW_TROJAN TIDAK ditemukan"
}

# ==========================================
# FUNGSI KIRIM NOTIFIKASI
# ==========================================
send_notification() {
    local chat_id="$1"
    local message="$2"
    local to_channel="${3:-false}"  # parameter baru untuk membedakan kirim ke channel atau user
    
    if [ -z "$BOT_TOKEN" ]; then
        log "❌ Token tidak ditemukan!"
        return 1
    fi
    
    # Encode message untuk URL
    message=$(echo "$message" | sed 's/ /%20/g' | sed 's/&/%26/g' | sed 's/+/%2B/g' | sed 's/#/%23/g' | sed 's/|/%7C/g')
    
    local target="$chat_id"
    log "📤 Mengirim notifikasi ke $target"
    
    response=$(curl -s -X POST "https://api.telegram.org/bot$BOT_TOKEN/sendMessage" \
        -d chat_id="$target" \
        -d text="$message" \
        -d parse_mode="HTML")
    
    if echo "$response" | grep -q '"ok":true'; then
        log "✅ Notifikasi terkirim"
        return 0
    else
        log "❌ Gagal kirim: $response"
        return 1
    fi
}

