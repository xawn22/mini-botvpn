# ==========================================
# FUNGSI GET SALDO
# ==========================================
get_balance() {
    local user_id=$1
    sqlite3 $DB_PATH "SELECT balance FROM saldo WHERE user_id = $user_id" 2>/dev/null
}

# ==========================================
# FUNGSI UPDATE SALDO
# ==========================================
update_balance() {
    local user_id=$1
    local amount=$2
    local desc=$3
    
    sqlite3 $DB_PATH "UPDATE saldo SET balance = balance + $amount WHERE user_id = $user_id" 2>/dev/null
    sqlite3 $DB_PATH "INSERT INTO transaksi (user_id, type, amount, description) VALUES ($user_id, 'debit', $(( -amount )), '$desc')" 2>/dev/null
}

# ==========================================
# FUNGSI GET SCRIPT RENEW PATH
# ==========================================
get_renew_script() {
    local protocol=$1
    
    case $protocol in
        ssh) echo "$RENEW_SSH" ;;
        vmess) echo "$RENEW_VMESS" ;;
        vless) echo "$RENEW_VLESS" ;;
        trojan) echo "$RENEW_TROJAN" ;;
        *) echo "" ;;
    esac
}

# ==========================================
# FUNGSI GET PRICE
# ==========================================
get_price() {
    local protocol=$1
    local days=$2
    
    case $protocol in
        ssh) price=$(( PRICE_SSH * days )) ;;
        vmess) price=$(( PRICE_VMESS * days )) ;;
        vless) price=$(( PRICE_VLESS * days )) ;;
        trojan) price=$(( PRICE_TROJAN * days )) ;;
        *) price=0 ;;
    esac
    
    echo $price
}

# ==========================================
# FUNGSI CEK EXPIRED AKUN
# ==========================================
check_account_expiry() {
    local protocol=$1
    local username=$2
    
    case $protocol in
        ssh)
            if id "$username" &>/dev/null; then
                exp_str=$(chage -l "$username" 2>/dev/null | grep "Account expires" | cut -d: -f2 | xargs)
                if [ "$exp_str" != "never" ] && [ -n "$exp_str" ]; then
                    date -d "$exp_str" +%Y-%m-%d 2>/dev/null
                fi
            fi
            ;;
        vmess)
            if [ -f "/etc/xray/config.json" ]; then
                grep "### $username" /etc/xray/config.json | head -1 | awk '{print $3}' | tr -d '\n\r' | xargs
            fi
            ;;
        vless)
            if [ -f "/etc/xray/config.json" ]; then
                grep "#& $username" /etc/xray/config.json | head -1 | awk '{print $3}' | tr -d '\n\r' | xargs
            fi
            ;;
        trojan)
            if [ -f "/etc/xray/config.json" ]; then
                grep "#! $username" /etc/xray/config.json | head -1 | awk '{print $3}' | tr -d '\n\r' | xargs
            fi
            ;;
    esac
}

# ==========================================
# FUNGSI PROSES RENEW
# ==========================================
process_renew() {
    local user_id=$1
    local protocol=$2
    local username=$3
    local days=$4
    local price=$5
    
    # Dapatkan info user untuk display di channel
    local user_display=$(get_user_info $user_id)
    local user_sensor=$(sensor_username "$user_display")
    
    # Cek saldo
    balance=$(get_balance $user_id)
    balance=${balance:-0}
    
    log "💰 Saldo user: Rp $balance"
    log "💰 Harga renew: Rp $price"
    
    if [ $balance -ge $price ]; then
        # Potong saldo
        update_balance $user_id -$price "Auto Renew $protocol $username +$days hari"
        log "✅ Saldo dipotong Rp $price"
        
        # Dapatkan script path
        script_path=$(get_renew_script $protocol)
        
        if [ -n "$script_path" ] && [ -f "$script_path" ]; then
            log "📦 Menjalankan script renew: $script_path"
            
            # Jalankan script renew dengan input: username, days, quota, iplimit
            echo -e "$username\n$days\n250\n4" | bash "$script_path" > /dev/null 2>&1
            
            if [ $? -eq 0 ]; then
                new_balance=$((balance - price))
                new_exp=$(date -d "+$days days" +%Y-%m-%d)
                
                # Simpan log ke database
                sqlite3 $DB_PATH "INSERT INTO auto_renew_logs (user_id, protocol, account_username, action, amount, status, message) VALUES ($user_id, '$protocol', '$username', 'renew', $price, 'success', 'Auto renew berhasil')" 2>/dev/null
                
                # Kirim notifikasi ke user
                user_message=$(format_user_message "$protocol" "$username" "$days" "$price" "$new_exp" "$new_balance" "success")
                send_notification "$user_id" "$user_message"
                log "✅ Notifikasi sukses terkirim ke user $user_id"
                
                # Kirim juga ke channel dengan format yang lebih rapi
                if [ -n "$CHANNEL_ID" ] && [ "$CHANNEL_ID" != "null" ] && [ "$CHANNEL_ID" != "0" ]; then
                    channel_message=$(format_channel_message "$protocol" "$username" "$days" "$price" "$new_exp" "$user_sensor")
                    send_notification "$CHANNEL_ID" "$channel_message"
                    log "✅ Notifikasi terkirim ke channel"
                fi
                
                log "✅ Auto renew berhasil untuk $username"
                return 0
            else
                log "❌ Script renew gagal dijalankan"
                return 1
            fi
        else
            log "❌ Script renew tidak ditemukan: $script_path"
            
            # Notifikasi gagal karena script tidak ditemukan
            local message="╭━━━━━━━━━━━━━━━━━━━━━━━━━━╮%0A"
            message+="┃     ❌ SYSTEM ERROR       ┃%0A"
            message+="╰━━━━━━━━━━━━━━━━━━━━━━━━━━╯%0A%0A"
            message+="Script renew untuk $protocol tidak ditemukan.%0A"
            message+="Hubungi admin untuk memperbaiki."
            
            send_notification "$user_id" "$message"
            return 1
        fi
    else
        # Saldo tidak cukup
        kurang=$((price - balance))
        
        # Nonaktifkan auto renew
        sqlite3 $DB_PATH "UPDATE auto_renew_settings SET is_active = 0 WHERE user_id = $user_id AND protocol = '$protocol' AND account_username = '$username'" 2>/dev/null
        
        # Kirim notifikasi gagal ke user
        local proto_name=$(echo "$protocol" | tr '[:lower:]' '[:upper:]')
        local message="╭━━━━━━━━━━━━━━━━━━━━━━━━━━╮%0A"
        message+="┃   ❌ AUTO RENEW GAGAL    ┃%0A"
        message+="╰━━━━━━━━━━━━━━━━━━━━━━━━━━╯%0A%0A"
        message+="Akun $proto_name <code>$username</code>%0A"
        message+="akan expired besok.%0A%0A"
        message+="💰 Dibutuhkan: Rp $price%0A"
        message+="💵 Saldo: Rp $balance%0A"
        message+="🔻 Kekurangan: Rp $kurang%0A%0A"
        message+="⚠️ Auto Renew dinonaktifkan%0A"
        message+="Silakan Topup dan aktifkan kembali"
        
        send_notification "$user_id" "$message"
        log "❌ Saldo tidak cukup untuk $username"
        
        # Kirim notifikasi ke channel (optional)
        if [ -n "$CHANNEL_ID" ] && [ "$CHANNEL_ID" != "null" ] && [ "$CHANNEL_ID" != "0" ]; then
            local channel_msg="╭━━━━━━━━━━━━━━━━━━━━━━━━━━╮%0A"
            channel_msg+="┃   ⚠️ AUTO RENEW GAGAL    ┃%0A"
            channel_msg+="╰━━━━━━━━━━━━━━━━━━━━━━━━━━╯%0A%0A"
            channel_msg+="👤 Pembeli: $user_sensor%0A"
            channel_msg+="📦 Akun: $proto_name%0A"
            channel_msg+="👤 Username: $(sensor_username "$username")%0A"
            channel_msg+="💰 Harga: Rp $price%0A"
            channel_msg+="❌ Gagal: Saldo tidak cukup"
            
            send_notification "$CHANNEL_ID" "$channel_msg"
        fi
        
        return 1
    fi
}

# ==========================================
# MAIN
# ==========================================

# Baca config.json
read_config

log "${GREEN}========== AUTO RENEW EXECUTOR ==========${NC}"

today=$(date +%Y-%m-%d)
tomorrow=$(date -d "+1 day" +%Y-%m-%d)
log "📅 Hari ini: $today"
log "📅 Besok: $tomorrow"

# Cek apakah database ada
if [ ! -f "$DB_PATH" ]; then
    log "${RED}❌ Database tidak ditemukan: $DB_PATH${NC}"
    exit 1
fi

# ==========================================
# CEK AUTO RENEW SETTINGS
# ==========================================
log "${YELLOW}🔍 Mencari akun yang akan expired besok...${NC}"

# Ambil semua setting auto renew yang aktif
sqlite3 $DB_PATH "SELECT user_id, protocol, account_username FROM auto_renew_settings WHERE is_active = 1" 2>/dev/null | while IFS='|' read user_id protocol username; do
    
    log "🔍 Processing: User $user_id, $protocol, $username"
    
    # Cek tanggal expired akun
    exp_date=$(check_account_expiry "$protocol" "$username")
    
    if [ -n "$exp_date" ]; then
        log "📅 Exp date: $exp_date"
        
        if [ "$exp_date" == "$tomorrow" ]; then
            log "✅ AKUN INI AKAN EXPIRE BESOK!"
            
            # Proses renew (default 30 hari)
            days=30
            price=$(get_price "$protocol" "$days")
            
            process_renew "$user_id" "$protocol" "$username" "$days" "$price"
            
        elif [ "$exp_date" \< "$tomorrow" ]; then
            log "⚠️ Akun sudah expired! Nonaktifkan auto renew"
            sqlite3 $DB_PATH "UPDATE auto_renew_settings SET is_active = 0 WHERE user_id = $user_id AND protocol = '$protocol' AND account_username = '$username'" 2>/dev/null
            
            # Notifikasi ke user
            local proto_name=$(echo "$protocol" | tr '[:lower:]' '[:upper:]')
            local message="╭━━━━━━━━━━━━━━━━━━━━━━━━━━╮%0A"
            message+="┃   ⚠️ AUTO RENEW OFF       ┃%0A"
            message+="╰━━━━━━━━━━━━━━━━━━━━━━━━━━╯%0A%0A"
            message+="Akun $proto_name <code>$username</code>%0A"
            message+="sudah expired.%0A%0A"
            message+="Auto Renew dinonaktifkan.%0A"
            message+="Silakan aktifkan kembali jika ingin."
            
            send_notification "$user_id" "$message"
            
        else
            diff_days=$(( ( $(date -d "$exp_date" +%s) - $(date -d "$today" +%s) ) / 86400 ))
            log "❌ Bukan expired besok (masih $diff_days hari lagi)"
        fi
    else
        log "❌ Tidak dapat membaca tanggal expired untuk $username"
        
        # Kemungkinan akun sudah dihapus
        sqlite3 $DB_PATH "UPDATE auto_renew_settings SET is_active = 0 WHERE user_id = $user_id AND protocol = '$protocol' AND account_username = '$username'" 2>/dev/null
    fi
